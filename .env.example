# IDENTIX Application Configuration
# Copy this to .env and fill in your actual values

# ============================================
# Database Configuration
# ============================================
# MongoDB Atlas connection string
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name
# Get from: https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://identix_app:PASSWORD@cluster0.xxxxx.mongodb.net/facial_landmark_db?retryWrites=true&w=majority

# ============================================
# Flask Configuration
# ============================================
# Secret key for session encryption
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-this-value

# Environment mode
# Set to 'development' for debugging, 'production' for deployment
FLASK_ENV=development

# Debug mode (only for development!)
# Set to True for detailed error messages, False for production
DEBUG=False

# ============================================
# Server Configuration
# ============================================
# Port number (auto-detected on Render/Hugging Face)
# Local testing: 5000
PORT=5000

# Host to bind to (0.0.0.0 for production, localhost for development)
HOST=0.0.0.0

# ============================================
# Optional: Cloud Storage (Cloudinary)
# ============================================
# Uncomment if using Cloudinary for image storage
# Get from: https://cloudinary.com
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ============================================
# Optional: Email Configuration
# ============================================
# For email notifications or password reset
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-specific-password

# ============================================
# Optional: Model Configuration
# ============================================
# Device for inference: 'cpu' or 'cuda'
# Auto-detected if not specified, override if needed
DEVICE=auto

# Model type: 'bisenet', 'unet', 'deeplab', 'vit'
MODEL_TYPE=bisenet

# ============================================
# Optional: Feature Flags
# ============================================
# Enable/disable features for development
ENABLE_MEDIAPIPE=False
ENABLE_GPU=True
LAZY_LOAD=False  # For slower devices
DEMO_MODE=False  # Limited functionality for demos

# ============================================
# Optional: Logging Configuration
# ============================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================
# Application-Specific Settings
# ============================================
# Maximum file upload size (in MB)
MAX_UPLOAD_MB=500

# Model inference timeout (in seconds)
INFERENCE_TIMEOUT=60

# Video FPS for extraction
VIDEO_FPS=10

# Confidence threshold for predictions
CONFIDENCE_THRESHOLD=0.5
